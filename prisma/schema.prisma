generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())

  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  recoveryCodeHash String?

  profile         PlayerProfile?
  trainingLogs    TrainingSession[]
  matches         Match[]
  conversations   CoachConversation[]
  drillLogs       DrillLog[]
  coachUsages     CoachMessageUsage[]
  whoopConnection WhoopConnection?
}

model PlayerProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillLevel  String // "Beginner" | "Intermediate" | "Competitive"
  playingHand String // "right" | "left"
  goals       String?
  weaknesses  String?
  strengths   String?

  // OeTV/OOeTV Verbandsdaten (manuelle Eingabe, kein Live-Sync)
  oetvRanking    String?
  itnValue       Float?
  oetvProfileUrl String?

  updatedAt DateTime @updatedAt
}

enum TrainingType {
  DRILL
  MATCH_PRACTICE
  LESSON
  FITNESS
}

model TrainingSession {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime
  durationMin   Int
  type          TrainingType
  focusAreas    String[]
  intensity     Int?
  notes         String?
  createdAt     DateTime     @default(now())
  whoopWorkoutId String?     @unique // gesetzt bei automatischem Whoop-Import, verhindert Duplikate

  @@index([userId, date])
}

// Verbindung zu einem Whoop-Konto (OAuth2) für Recovery/Sleep/Strain-Daten
// und automatischen Trainings-Import.
model WhoopConnection {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String    @db.Text
  refreshToken String    @db.Text
  expiresAt    DateTime
  whoopUserId  String?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

enum MatchResult {
  WIN
  LOSS
}

model Match {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime
  opponentName   String
  score          String
  result         MatchResult
  surface        String?
  aces           Int?
  doubleFaults   Int?
  winners        Int?
  unforcedErrors Int?
  firstServePct  Float?
  notes          String?
  createdAt      DateTime    @default(now())

  @@index([userId, date])
}

model CoachConversation {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String            @id @default(cuid())
  conversationId String
  conversation   CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant"
  content        String            @db.Text
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
}

enum DrillCategory {
  FOREHAND
  BACKHAND
  SERVE
  RETURN
  VOLLEY
  APPROACH
  FOOTWORK
  TACTICS
}

enum DrillDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// Kuratierte Trainings-Bibliothek (Referenzinhalte, nicht nutzerspezifisch)
model Drill {
  id          String          @id @default(cuid())
  title       String
  category    DrillCategory
  difficulty  DrillDifficulty
  situation   String // Kurzbeschreibung: wann/wofür dieser Drill
  setup       String          @db.Text
  execution   String          @db.Text
  coachingCue String          @db.Text
  reps        String
  focusTags   String[]
  videoQuery  String // Suchbegriff für Video-Link (kein fest verlinktes Video)
  createdAt   DateTime        @default(now())

  logs DrillLog[]

  @@index([category])
}

model DrillLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  drillId     String
  drill       Drill    @relation(fields: [drillId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())
  notes       String?

  @@index([userId, drillId])
  @@index([userId, completedAt])
}

// Zählt KI-Coach-Nachrichten pro Nutzer und Tag für ein einfaches Tages-Limit
model CoachMessageUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day       DateTime // auf Tagesbeginn normalisiert (00:00 UTC)
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, day])
}
